QWidget{
    font-family:Segoe UI;
    font-size:18px;
    background-color:#f6f7fb;
}
QFrame#frame_header{
    background-color:white;
    border-radius:18px;
    border:2px solid #e5e5e5;
}
QLabel#label_title{
    font-size:30px;
    font-weight:900;
    color:#58cc02;
}
QLabel#label_subtitle{
    font-size:14px;
    font-weight:600;
    color:#636e72;
}
QFrame#frame_quiz{
    background-color:white;
    border-radius:18px;
    border:2px solid #e5e5e5;
}
QLabel{
    color:#2d3436;
}
QRadioButton{
    background-color:#ffffff;
    border:2px solid #e5e5e5;
    border-radius:16px;
    padding:14px;
    font-size:16px;
    font-weight:700;
    color:#2d3436;
}
QRadioButton:hover{
    border:2px solid #58cc02;
    background-color:#f3ffe9;
}
QPushButton{
    border:none;
    border-radius:16px;
    padding:14px 22px;
    font-size:15px;
    font-weight:900;
}
QPushButton#btn_next{
    background-color:#58cc02;
    color:white;
}
QPushButton#btn_next:hover{
    background-color:#46a302;
}
QPushButton#btn_prev{
    background-color:#dfe6e9;
    color:#2d3436;
}
QPushButton#btn_prev:hover{
    background-color:#b2bec3;
}
QPushButton#btn_bai1, QPushButton#btn_bai2, QPushButton#btn_bai3, QPushButton#btn_bai4, QPushButton#btn_bai5{
    background-color:white;
    border:2px solid #e5e5e5;
    color:#2d3436;
    font-size:14px;
    font-weight:800;
    padding:12px;
}
QPushButton#btn_bai1:hover, QPushButton#btn_bai2:hover, QPushButton#btn_bai3:hover, QPushButton#btn_bai4:hover, QPushButton#btn_bai5:hover{
    border:2px solid #58cc02;
    background-color:#f3ffe9;
}
    

QLabel[role=&quot;question&quot;]{
    font-size:26px;
    font-weight:800;
    color:#222222;
}
QRadioButton[role=&quot;answer&quot;]{
    font-size:22px;
    font-weight:600;
    color:#222222;
}
QLabel[role=&quot;explain&quot;]{
    font-size:22px;
    font-weight:600;
    color:#444444;
}

</string>
