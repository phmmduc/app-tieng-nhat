             <property name="styleSheet">
              <string notr="true">/* ===== NÚT TRƯỚC (Xanh dương giống ảnh) ===== */
QPushButton#btn_truoc {
    color: white;
    font: 700 12pt &quot;Segoe UI&quot;;
    border: none;
    border-radius: 18px;
    padding: 6px 18px;

    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 rgb(0, 200, 255),
        stop:1 rgb(0, 140, 230)
    );
}

QPushButton#btn_truoc:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 rgb(60, 220, 255),
        stop:1 rgb(0, 160, 240)
    );
}

QPushButton#btn_truoc:pressed {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 rgb(0, 160, 220),
        stop:1 rgb(0, 120, 200)
    );
}


/* ===== NÚT TIẾP (Xanh lá giống ảnh) ===== */
QPushButton#btn_tiep {
    color: white;
    font: 700 12pt &quot;Segoe UI&quot;;
    border: none;
    border-radius: 18px;
    padding: 6px 18px;

    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 rgb(0, 255, 0),
        stop:1 rgb(0, 180, 0)
    );
}

QPushButton#btn_tiep:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 rgb(80, 255, 80),
        stop:1 rgb(0, 210, 0)
    );
}

QPushButton#btn_tiep:pressed {
    background: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 rgb(0, 200, 0),
        stop:1 rgb(0, 150, 0)
    );
}</string>
