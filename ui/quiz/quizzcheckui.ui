  <property name="styleSheet">
   <string notr="true">/* 1. Nền tổng thể của ứng dụng */
QWidget#centralwidget {
    background-color: #f4f6f8; /* Màu xám nhạt */
    font-family: 'Segoe UI', Arial, sans-serif;
}

/* 2. Thanh tiến độ (Header) */
QProgressBar {
    background-color: #e2e8f0;
    border: none;
    border-radius: 8px;
    color: transparent; /* Ẩn chữ số % */
    height: 16px;
}
QProgressBar::chunk {
    background-color: #58cc02; /* Xanh lá Duolingo */
    border-radius: 8px;
}

/* 3. Nhãn câu hỏi */
QLabel#label_cauhoi {
    background-color: #ffffff;
    border: 2px solid #e5e5e5;
    border-radius: 15px;
    padding: 15px 25px;
    font-size: 22px;
    font-weight: bold;
    color: #111b21;
}

/* 4. Thẻ Đáp án (A, B, C, D) - Trạng thái bình thường */
QPushButton {
    background-color: #ffffff;
    border: 2px solid #e5e5e5;
    border-radius: 15px;
    padding: 20px;
    font-size: 18px;
    font-weight: bold;
    color: #4b4b4b;
    text-align: left;
}
QPushButton:hover {
    background-color: #f7f9fa;
    border: 2px solid #d1d5db;
}

/* 5. Thẻ Đáp án - Trạng thái khi ĐƯỢC CHỌN (Màu xanh hiển thị đáp án đúng) */
QPushButton:checked {
    background-color: #e1febb; /* Nền xanh lá nhạt */
    border: 2px solid #58cc02; /* Viền xanh lá đậm */
    color: #195e35;
}

/* 6. Khung Giải thích (Màu vàng) */
QFrame#frame_giaithich {
    background-color: #fff4ce; 
    border: 1px solid #fde08b;
    border-radius: 15px;
}
QFrame#frame_giaithich QLabel {
    color: #3c3c3c;
    font-size: 16px;
    padding: 10px;
}

/* 7. Nút &quot;Trước&quot; (Xanh dương) */
QPushButton#btn_truoc {
    background-color: #1d528f;
    border: none;
    border-radius: 20px;
    color: white;
    font-size: 18px;
    font-weight: bold;
    text-align: center;
    padding: 12px;
}
QPushButton#btn_truoc:hover {
    background-color: #153c6b;
}

/* 8. Nút &quot;Tiếp&quot; (Xanh lá đậm) */
QPushButton#btn_tiep {
    background-color: #195e35;
    border: none;
    border-radius: 20px;
    color: white;
    font-size: 18px;
    font-weight: bold;
    text-align: center;
    padding: 12px;
}
QPushButton#btn_tiep:hover {
    background-color: #124225;
}</string>
