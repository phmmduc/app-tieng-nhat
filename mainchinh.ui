  <property name="styleSheet">
   <string notr="true">/* ================================================= */
/* 1. THIẾT KẾ TỔNG THỂ CHO TẤT CẢ NÚT BẤM           */
/* ================================================= */

QPushButton {
    /* Ép hiển thị màu xanh dương Duolingo làm nền */
    background-color: #1CB0F6; 
    color: white;
    font-weight: 900;
    font-size: 15px;
    
    /* Bo góc mập mạp 18px */
    border-radius: 18px; 
    
    /* Khai báo viền rõ ràng để Mac không tự chèn màu xám */
    border: 1px solid #1CB0F6;
    border-bottom: 5px solid #1899D6; /* Đế 3D */
    
    padding: 10px;
    margin-bottom: 5px;
}

/* ================================================= */
/* 2. HIỆU ỨNG KHI RÊ CHUỘT (HOVER) &amp; KHI ẤN (PRESSED) */
/* ================================================= */

QPushButton:hover, QPushButton:pressed {
    /* Biến toàn bộ nút thành màu xanh lá cây */
    background-color: #58CC02; 
    border: 1px solid #58CC02;
    border-bottom: 5px solid #58A700;
    color: white;
}

/* ================================================= */
/* 3. CÁC NGOẠI LỆ (NẾU CÓ)                           */
/* ================================================= */

/* Nút Bài Trước: Giữ nền trắng để phân biệt, nhưng vẫn bo góc mập */
#btn_truoc {
    background-color: #FFFFFF;
    color: #1CB0F6;
    border: 2px solid #E5E7EB;
    border-bottom: 5px solid #E5E7EB;
}

#btn_truoc:hover {
    background-color: #F7F9FA;
    border-color: #1CB0F6;
    border-bottom: 5px solid #1899D6;
}

/* Nút Đăng Xuất: Trắng viền đỏ */
#btn_dang_xuat {
    background-color: #FFFFFF;
    color: #FF5252;
    border: 2px solid #FFEAA7;
    border-bottom: 5px solid #FFD32A;
}</string>
